# config/guest/debian/12.env — Version-specific overrides for Debian 12 (Bookworm).
# TODO: implement — see /rebuild-project-doc/05_CONFIG_SCHEMA_REFERENCE.md §3.B

OS_VERSION="12"
OS_CODENAME="bookworm"

REPO_FAMILY="apt"
APT_SOURCE_MODE="list"
APT_SUITES="bookworm bookworm-updates bookworm-security bookworm-backports"
APT_COMPONENTS="main contrib non-free non-free-firmware"
APT_OFFICIAL_URIS="http://deb.debian.org/debian http://security.debian.org/debian-security"

OLS_REPO_PATH="/debian"
KERNEL_PACKAGE_PATTERN="linux-image-*"

ENABLE_VERSION_WORKAROUND="no"
VERSION_WORKAROUND_NOTE=""
