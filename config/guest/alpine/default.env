GUEST_OS_FAMILY=alpine
GUEST_OS_NAME=alpine
GUEST_REPO_DRIVER=apk
GUEST_PACKAGE_MANAGER=apk
GUEST_UPDATE_COMMAND=apk update
GUEST_UPGRADE_COMMAND=apk upgrade --no-cache
GUEST_INSTALL_COMMAND=apk add --no-cache
GUEST_AUTOREMOVE_COMMAND="
GUEST_CLEAN_CACHE_COMMAND=rm -rf /var/cache/apk/*
GUEST_DEFAULT_LOGIN_USER=alpine
GUEST_DEFAULT_LOGIN_HOME=/home/alpine
GUEST_LOGIN_USER_FALLBACKS=alpine root
GUEST_ROOT_AUTHORIZED_KEYS_SOURCE_USER=alpine
GUEST_ROOT_AUTHORIZED_KEYS_SOURCE_HOME=/home/alpine
GUEST_CONFIGURE_ROOT=1
GUEST_UNLOCK_ROOT=1
GUEST_COPY_AUTHORIZED_KEYS_TO_ROOT=1
GUEST_SSH_SERVICE=sshd
GUEST_SSH_PERMIT_ROOT_LOGIN=yes
GUEST_SSH_PASSWORD_AUTHENTICATION=yes
GUEST_SSH_PUBKEY_AUTHENTICATION=yes
GUEST_RESTART_SSH_AFTER_CHANGE=1
GUEST_REQUIRED_PACKAGES=qemu-guest-agent cloud-init sudo curl wget rsync ca-certificates
GUEST_ENABLE_SERVICES=qemu-guest-agent sshd
GUEST_DISABLE_SERVICES="
GUEST_SET_TIMEZONE=1
GUEST_TIMEZONE=Asia/Bangkok
GUEST_SET_LOCALE=1
GUEST_LOCALE=en_US.UTF-8
GUEST_LOCALE_METHOD=none
GUEST_DISABLE_FIREWALL=0
GUEST_FIREWALL_BACKEND=none
GUEST_DISABLE_AUTO_UPDATES=0
GUEST_ENABLE_VAULT_FALLBACK=0
GUEST_CLEAN_PACKAGE_CACHE=1
GUEST_CLEAN_HISTORY=1
GUEST_CLEAN_LOGS=1
GUEST_CLEAN_TMP=1
GUEST_TRUNCATE_MACHINE_ID=1
GUEST_REMOVE_SSH_HOST_KEYS=1
GUEST_CLOUD_INIT_CLEAN_BEFORE_CAPTURE=1
GUEST_FSTRIM_BEFORE_SHUTDOWN=1
GUEST_FINAL_SHUTDOWN=1
