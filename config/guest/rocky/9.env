# -----------------------------------------------------------------------------
# OpenStack Image Pipeline - guest env example
# Purpose:
#   - This file is intended for config/guest/<os>.env
#   - Keep the schema stable across OS families so AI/scripts can consume it
#   - Prefer booleans/lists over hard-coded shell, but include hints where useful
#
# Notes:
#   - Root password should come from settings/guest-access.env, not be hardcoded here
#   - This file is intentionally "OpenStack generic" and does NOT hardcode guest DNS
#   - For LEGACY_MIRROR failover, always test official repo first, backup repo files, inject LEGACY_MIRROR,
#     validate, and rollback on failure
# -----------------------------------------------------------------------------
# =============================================================================
# Identity
# =============================================================================
GUEST_SCHEMA_VERSION=2026-03-22
GUEST_ID=rocky-9
GUEST_DISPLAY_NAME="Rocky Linux 9 Generic Cloud"
GUEST_OS_FAMILY=rhel
GUEST_OS_NAME=rocky
GUEST_OS_VERSION=9
GUEST_OS_MAJOR=9
GUEST_IMAGE_VARIANT=generic-cloud
GUEST_ARCH=x86_64

# =============================================================================
# Login / SSH / root
# =============================================================================
GUEST_DEFAULT_LOGIN_USER=rocky
GUEST_DEFAULT_LOGIN_HOME=/home/rocky
GUEST_LOGIN_USER_FALLBACKS="rocky cloud-user root"
GUEST_ROOT_AUTHORIZED_KEYS_SOURCE_USER=rocky
GUEST_ROOT_AUTHORIZED_KEYS_SOURCE_HOME=/home/rocky
GUEST_CONFIGURE_ROOT=1
GUEST_UNLOCK_ROOT=1
GUEST_COPY_AUTHORIZED_KEYS_TO_ROOT=1
GUEST_ROOT_PASSWORD_FROM_ENV=ROOT_PASSWORD
GUEST_SSH_SERVICE=sshd
GUEST_SSHD_DROPIN_FILE=/etc/ssh/sshd_config.d/99-image-build.conf
GUEST_SSH_PERMIT_ROOT_LOGIN=yes
GUEST_SSH_PASSWORD_AUTHENTICATION=yes
GUEST_SSH_PUBKEY_AUTHENTICATION=yes
GUEST_SSH_KBD_INTERACTIVE_AUTHENTICATION=no
GUEST_SSH_USE_PAM=yes
GUEST_RESTART_SSH_AFTER_CHANGE=1

# =============================================================================
# Cloud-init
# =============================================================================
GUEST_EXPECT_CLOUD_INIT=1
GUEST_CLOUD_INIT_PACKAGE=cloud-init
GUEST_WAIT_FOR_CLOUD_INIT=1
GUEST_CLOUD_INIT_WAIT_COMMAND="cloud-init status --wait || cloud-init status || true"
GUEST_CLOUD_INIT_CLEAN_COMMAND="cloud-init clean --logs --seed || true"
GUEST_KEEP_CLOUD_INIT_ENABLED=1
GUEST_CLOUD_METADATA_HINT=openstack

# =============================================================================
# Locale / timezone / network policy
# =============================================================================
GUEST_SET_TIMEZONE=1
GUEST_TIMEZONE=Asia/Bangkok
GUEST_SET_LOCALE=1
GUEST_LOCALE=en_US.UTF-8
GUEST_LOCALE_METHOD=localectl
GUEST_NETWORK_STACK=NetworkManager
GUEST_MANAGE_DNS=0
GUEST_DISABLE_FIREWALL=1
GUEST_FIREWALL_BACKEND=firewalld
GUEST_FIREWALL_DISABLE_UNITS="firewalld.service"
GUEST_DISABLE_MOTD_NEWS=0
GUEST_SELINUX_MODE=enforcing

# =============================================================================
# Package manager / update / upgrade
# =============================================================================
GUEST_PACKAGE_MANAGER=dnf
GUEST_UPDATE_COMMAND="dnf -y makecache"
GUEST_UPGRADE_COMMAND="dnf -y upgrade --refresh"
GUEST_INSTALL_COMMAND="dnf -y install"
GUEST_AUTOREMOVE_COMMAND="dnf -y autoremove"
GUEST_CLEAN_CACHE_COMMAND="dnf clean all && rm -rf /var/cache/dnf/*"
GUEST_REQUIRED_PACKAGES="qemu-guest-agent cloud-init cloud-utils-growpart sudo curl wget rsync ca-certificates"
GUEST_OPTIONAL_PACKAGES="vim-minimal bash-completion"
GUEST_ENABLE_SERVICES="qemu-guest-agent sshd"
GUEST_DISABLE_SERVICES="firewalld"
GUEST_RESTART_SERVICES_AFTER_CONFIG="sshd qemu-guest-agent"
GUEST_RUN_BASELINE_UPDATE=1
GUEST_RUN_FULL_UPGRADE=1
GUEST_REBOOT_AFTER_UPGRADE=1
GUEST_REBOOT_TIMEOUT_SEC=1800

# Keep at most 2 kernels after upgrade/capture
GUEST_KERNEL_RETENTION=2
GUEST_KERNEL_PRUNE_STRATEGY=dnf-installonly-limit
GUEST_DNF_INSTALLONLY_LIMIT=2

# Disable automatic background package work inside the guest
GUEST_DISABLE_AUTO_UPDATES=1
GUEST_DISABLE_AUTO_UPDATE_UNITS="dnf-automatic.timer dnf-automatic-install.timer dnf-automatic-download.timer dnf-makecache.timer"

# =============================================================================
# Repo / LEGACY_MIRROR failover
# For RHEL-family logic: backup *.repo, disable mirrorlist/metalink, inject baseurl,
# validate with dnf makecache/upgrade, rollback if LEGACY_MIRROR fails
# =============================================================================
GUEST_ENABLE_LEGACY_MIRROR_FAILOVER=1
GUEST_LEGACY_MIRROR_URL=http://mirrors.openlandscape.cloud
GUEST_LEGACY_MIRROR_SKIP_IF_UNAVAILABLE=1
GUEST_REPO_DRIVER=dnf-repo
GUEST_REPO_BACKUP_DIR=/var/backups/image-build/repos
GUEST_REPO_FILES="/etc/yum.repos.d/*.repo"
GUEST_REPO_DISABLE_KEYS="mirrorlist metalink"
GUEST_REPO_ENABLE_KEY=baseurl
GUEST_REPO_BASELINE_UPDATE_COMMAND="dnf -y makecache"
GUEST_REPO_VALIDATION_COMMAND="dnf clean all && dnf -y makecache"
GUEST_REPO_FAILBACK_ACTION=restore-backup
GUEST_ENABLE_VAULT_FALLBACK=1
GUEST_VAULT_URL="https://dl.rockylinux.org/vault/rocky"
GUEST_VAULT_VALIDATION_COMMAND="dnf clean all && dnf -y makecache"

# =============================================================================
# Capture / generalize / cleanup
# =============================================================================
GUEST_CLEAN_PACKAGE_CACHE=1
GUEST_CLEAN_HISTORY=1
GUEST_CLEAN_LOGS=1
GUEST_CLEAN_TMP=1
GUEST_TRUNCATE_MACHINE_ID=1
GUEST_REMOVE_SSH_HOST_KEYS=1
GUEST_CLOUD_INIT_CLEAN_BEFORE_CAPTURE=1
GUEST_FSTRIM_BEFORE_SHUTDOWN=1
GUEST_FINAL_SHUTDOWN=1

# Extra cleanup hints for the build logic
GUEST_HISTORY_FILES="/root/.bash_history /home/*/.bash_history"
GUEST_TMP_PATHS="/tmp/* /var/tmp/*"
GUEST_LOG_PATHS="/var/log/*.log /var/log/cloud-init*.log /var/log/journal/*"
GUEST_MACHINE_ID_FILES="/etc/machine-id /var/lib/dbus/machine-id"

# =============================================================================
# Validation hints
# =============================================================================
GUEST_VALIDATE_EXPECT_SSH=1
GUEST_VALIDATE_EXPECT_QGA=1
GUEST_VALIDATE_EXPECT_CLOUD_INIT=1
GUEST_VALIDATE_EXPECT_ROOT_LOGIN=1
GUEST_VALIDATE_EXPECT_TIMEZONE="Asia/Bangkok"
GUEST_VALIDATE_EXPECT_LOCALE="en_US.UTF-8"

# =============================================================================
# Build policy notes for downstream logic
# =============================================================================
GUEST_FAIL_ON_PACKAGE_ERROR=1
GUEST_FAIL_ON_REPO_ERROR=1
GUEST_FAIL_ON_CLOUD_INIT_ERROR=1
GUEST_PRESERVE_OFFICIAL_REPO_FALLBACK=1
GUEST_PREFER_IDEMPOTENT_CHANGES=1
