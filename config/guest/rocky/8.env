# config/guest/rocky/8.env
GUEST_SCHEMA_VERSION=2026-03-23
GUEST_ID=rocky-8
GUEST_DISPLAY_NAME="Rocky Linux 8 Generic Cloud"
GUEST_OS_FAMILY=rhel
GUEST_OS_NAME=rocky
GUEST_OS_VERSION=8
GUEST_OS_MAJOR=8
GUEST_IMAGE_VARIANT=generic-cloud
GUEST_ARCH=x86_64

GUEST_DEFAULT_LOGIN_USER=rocky
GUEST_DEFAULT_LOGIN_HOME=/home/rocky
GUEST_LOGIN_USER_FALLBACKS="rocky cloud-user root"

GUEST_VAULT_URL="https://dl.rockylinux.org/vault/rocky/8"
