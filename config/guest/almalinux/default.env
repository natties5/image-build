# config/guest/almalinux/default.env — Default guest policy for all AlmaLinux versions.
# Purpose:
#   - Define shared settings for all AlmaLinux versions (8, 9, 10, etc.)
#   - Ensure DNF-based repo handling and NO apt/apt-get fallback
#   - Follow standard GUEST_* schema for configure_guest.sh

# =============================================================================
# Identity / Family
# =============================================================================
GUEST_OS_FAMILY=rhel
GUEST_OS_NAME=almalinux
GUEST_REPO_DRIVER=dnf-repo

# =============================================================================
# Package Manager (DNF only for AlmaLinux)
# =============================================================================
GUEST_PACKAGE_MANAGER=dnf
GUEST_UPDATE_COMMAND="dnf -y makecache"
GUEST_UPGRADE_COMMAND="dnf -y upgrade --refresh"
GUEST_INSTALL_COMMAND="dnf -y install"
GUEST_AUTOREMOVE_COMMAND="dnf -y autoremove"
GUEST_CLEAN_CACHE_COMMAND="dnf clean all && rm -rf /var/cache/dnf/*"

# =============================================================================
# Repo / Vault Failover
# =============================================================================
GUEST_ENABLE_VAULT_FALLBACK=1
GUEST_VAULT_URL="https://repo.almalinux.org/vault"
GUEST_VAULT_VALIDATION_COMMAND="dnf clean all && dnf -y makecache"

GUEST_REPO_BACKUP_DIR=/var/backups/image-build/repos
GUEST_REPO_FILES="/etc/yum.repos.d/*.repo"
GUEST_REPO_DISABLE_KEYS="mirrorlist metalink"
GUEST_REPO_ENABLE_KEY=baseurl
GUEST_REPO_BASELINE_UPDATE_COMMAND="dnf -y makecache"
GUEST_REPO_VALIDATION_COMMAND="dnf clean all && dnf -y makecache"
GUEST_REPO_FAILBACK_ACTION=restore-backup

# =============================================================================
# Standard Configuration
# =============================================================================
GUEST_SET_TIMEZONE=1
GUEST_TIMEZONE="Asia/Bangkok"
GUEST_SET_LOCALE=1
GUEST_LOCALE="en_US.UTF-8"
GUEST_LOCALE_METHOD=localectl

GUEST_CONFIGURE_ROOT=1
GUEST_UNLOCK_ROOT=1
GUEST_COPY_AUTHORIZED_KEYS_TO_ROOT=1
GUEST_SSH_SERVICE=sshd
GUEST_RESTART_SSH_AFTER_CHANGE=1

GUEST_DISABLE_FIREWALL=1
GUEST_FIREWALL_BACKEND=firewalld
GUEST_FIREWALL_DISABLE_UNITS="firewalld.service"

GUEST_DISABLE_AUTO_UPDATES=1
GUEST_DISABLE_AUTO_UPDATE_UNITS="dnf-automatic.timer dnf-automatic-install.timer dnf-automatic-download.timer dnf-makecache.timer"

# =============================================================================
# Clean / Generalize
# =============================================================================
GUEST_CLEAN_PACKAGE_CACHE=1
GUEST_CLEAN_HISTORY=1
GUEST_CLEAN_LOGS=1
GUEST_CLEAN_TMP=1
GUEST_TRUNCATE_MACHINE_ID=1
GUEST_REMOVE_SSH_HOST_KEYS=1
GUEST_CLOUD_INIT_CLEAN_BEFORE_CAPTURE=1
GUEST_FSTRIM_BEFORE_SHUTDOWN=1
GUEST_FINAL_SHUTDOWN=1
