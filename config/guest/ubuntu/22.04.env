# config/guest/ubuntu/22.04.env — Version-specific overrides for Ubuntu 22.04 (Jammy).
# TODO: implement — see /rebuild-project-doc/05_CONFIG_SCHEMA_REFERENCE.md §3.B

OS_VERSION="22.04"
OS_CODENAME="jammy"

REPO_FAMILY="apt"
APT_SOURCE_MODE="list"
APT_SUITES="jammy jammy-updates jammy-security jammy-backports"
APT_COMPONENTS="main restricted universe multiverse"
APT_OFFICIAL_URIS="http://archive.ubuntu.com/ubuntu http://security.ubuntu.com/ubuntu"

OLS_REPO_PATH="/ubuntu"
KERNEL_PACKAGE_PATTERN="linux-image-*"

ENABLE_VERSION_WORKAROUND="no"
VERSION_WORKAROUND_NOTE=""
