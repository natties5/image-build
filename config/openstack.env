# Glance import config
# ปล่อยว่าง PIPELINE_ROOT เพื่อใช้ root ของ repo อัตโนมัติ
PIPELINE_ROOT=""

# Source manifest from stage 01
SUMMARY_FILE=""
UBUNTU_MANIFEST_DIR=""

# Output paths
OPENSTACK_MANIFEST_DIR=""
STATE_DIR=""
LOG_DIR=""

# Naming
BASE_IMAGE_NAME_TEMPLATE="ubuntu-{version}-base-official"

# Visibility: private | public | community | shared
IMAGE_VISIBILITY="private"

# basic properties / tags
IMAGE_TAGS="source:official,stage:base,os:ubuntu"
SET_OS_DISTRO_PROPERTY="yes"
SET_OS_VERSION_PROPERTY="yes"

# behavior when image name already exists:
# error | skip | replace
ON_EXISTS="error"

# wait policy after image create
WAIT_FOR_ACTIVE="yes"
WAIT_TIMEOUT_SECONDS="1800"
WAIT_INTERVAL_SECONDS="10"
