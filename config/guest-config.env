# Guest config policy for stage 06
OLS_BASE_URL="http://mirrors.openlandscape.cloud/ubuntu"
OLD_RELEASES_URL="https://old-releases.ubuntu.com/ubuntu"
OFFICIAL_ARCHIVE_URL="http://archive.ubuntu.com/ubuntu"
OFFICIAL_SECURITY_URL="http://security.ubuntu.com/ubuntu"

DEFAULT_LANG="en_US.UTF-8"
EXTRA_LOCALES="th_TH.UTF-8"
TIMEZONE="Asia/Bangkok"
KERNEL_KEEP="2"

DO_UPGRADE="yes"
REBOOT_AFTER_UPGRADE="yes"
WAIT_CLOUD_INIT="yes"
DISABLE_AUTO_UPDATES="yes"
DISABLE_MOTD_NEWS="yes"
DISABLE_GUEST_FIREWALL="yes"
ROOT_SSH_PERMIT="yes"
ROOT_PASSWORD_AUTH="yes"
ROOT_PUBKEY_AUTH="yes"
ROOT_AUTHORIZED_KEY=""
