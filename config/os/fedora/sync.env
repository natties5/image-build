# config/os/fedora/sync.env ? Discovery rules for Fedora cloud images.
# Upstream primary: https://dl.fedoraproject.org/pub/fedora/linux/releases/
# Fallback archive: https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/

OS_FAMILY="fedora"
MIN_VERSION="41"

# Space-separated list of versions to track (all >= MIN_VERSION)
TRACKED_VERSIONS="41 42 43"
AUTO_DISCOVER="1"
LTS_ONLY="0"

# index_scan: scan the directory listing to find the dynamically-named checksum file
DISCOVERY_MODE="index_scan"

# sort_version: if multiple build numbers exist, take the highest (sort -V)
LATEST_LOGIC="sort_version"

# Primary for current Fedora releases
INDEX_URL_TEMPLATE="https://dl.fedoraproject.org/pub/fedora/linux/releases/{VERSION}/Cloud/x86_64/images"

# Fallback for archived/EOL Fedora releases
INDEX_URL_FALLBACK="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/{VERSION}/Cloud/x86_64/images"

# Regex pattern to locate the checksum file in the directory listing.
CHECKSUM_FILE="Fedora-Cloud-[0-9]+-[0-9.]+-x86_64-CHECKSUM"

HASH_ALGO="sha256"
ARCH_PRIORITY="x86_64 amd64"
FORMAT_PRIORITY="qcow2"

# Match Fedora Cloud Base Generic qcow2 image.
IMAGE_REGEX="^Fedora-Cloud-Base-Generic-{VERSION}-[0-9.]+\.x86_64\.qcow2$"

DRY_RUN_SUPPORTED="yes"
