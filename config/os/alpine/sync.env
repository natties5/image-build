# config/os/alpine/sync.env — Discovery rules for Alpine Linux cloud images.
# Upstream: https://dl-cdn.alpinelinux.org/alpine/

OS_FAMILY=alpine
MIN_VERSION=3.21
TRACKED_VERSIONS=3.21
AUTO_DISCOVER=1
LTS_ONLY=0
DISCOVERY_MODE=index_scan
LATEST_LOGIC=sort_version
INDEX_URL_TEMPLATE=https://dl-cdn.alpinelinux.org/alpine/v{VERSION}/releases/cloud
CHECKSUM_FILE=^generic_alpine-.*-x86_64-bios-cloudinit-r[0-9]+\.qcow2\.sha512$
HASH_ALGO=sha512
ARCH_PRIORITY=x86_64
FORMAT_PRIORITY=qcow2
IMAGE_REGEX=^generic_alpine-.*-x86_64-bios-cloudinit-r[0-9]+\.qcow2$
DRY_RUN_SUPPORTED=yes
