# config/os/debian/sync.env — Discovery rules for Debian cloud images.
# Upstream: https://cloud.debian.org/images/cloud/

OS_FAMILY="debian"
MIN_VERSION="13"

# Space-separated list of versions to track (all >= MIN_VERSION)
TRACKED_VERSIONS="13"
AUTO_DISCOVER="1"
LTS_ONLY="0"

# checksum_driven: fetch CHECKSUM_FILE from index URL
DISCOVERY_MODE="checksum_driven"

# current_folder: the latest/ directory is always the most current build
LATEST_LOGIC="current_folder"

# Debian uses codenames in URL paths.
# CODENAME_MAP format: "<version>:<codename>" pairs space-separated
CODENAME_MAP="12:bookworm 13:trixie 14:forky 15:duke"

# {CODENAME} is resolved from CODENAME_MAP at runtime; {VERSION} also replaced
INDEX_URL_TEMPLATE="https://cloud.debian.org/images/cloud/{CODENAME}/latest"

CHECKSUM_FILE="SHA512SUMS"
HASH_ALGO="sha512"
ARCH_PRIORITY="amd64"
FORMAT_PRIORITY="qcow2"

# Match generic cloud images for amd64 (not *.raw, not genericcloud variant unless no generic)
IMAGE_REGEX="^debian-[0-9]+-generic-amd64\.(qcow2|raw)$"

DRY_RUN_SUPPORTED="yes"
