# Ubuntu OS family defaults — all versions inherit these
OS_FAMILY=ubuntu
OS_IMPLEMENTED=yes
ARCH=amd64
LTS_ONLY=1
CURL_RETRY=3
CURL_CONNECT_TIMEOUT=20
VERIFY_SHA256=1
UBUNTU_RELEASES_BASE_URL=https://cloud-images.ubuntu.com/releases
IMAGE_PATTERNS=ubuntu-{version}-server-cloudimg-{arch}.img ubuntu-{version}-server-cloudimg-{arch}-disk-kvm.img
