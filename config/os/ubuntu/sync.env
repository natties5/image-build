# config/os/ubuntu/sync.env — Discovery rules for Ubuntu cloud images.
# Upstream: https://cloud-images.ubuntu.com/releases/

OS_FAMILY="ubuntu"
MIN_VERSION="18.04"

# Space-separated list of versions to track (all >= MIN_VERSION)
TRACKED_VERSIONS="18.04 20.04 22.04 24.04"

# checksum_driven: fetch CHECKSUM_FILE from index URL, parse entries
DISCOVERY_MODE="checksum_driven"

# current_folder: the index URL already points to the current/latest release
LATEST_LOGIC="current_folder"

# {VERSION} is replaced by the actual version string (e.g. 24.04)
INDEX_URL_TEMPLATE="https://cloud-images.ubuntu.com/releases/{VERSION}/release"

# Checksum file in the release directory
CHECKSUM_FILE="SHA256SUMS"

HASH_ALGO="sha256"
ARCH_PRIORITY="amd64 x86_64"
FORMAT_PRIORITY="img qcow2"

# Regex to match only cloud image files for the given version.
# {VERSION} will be substituted at runtime.
IMAGE_REGEX="^ubuntu-{VERSION}-server-cloudimg-amd64\.(img|qcow2)$"

DRY_RUN_SUPPORTED="yes"
