# Ubuntu source/discovery policy
OS_FAMILY="ubuntu"
OS_IMPLEMENTED="yes"
UBUNTU_RELEASES_BASE_URL="https://cloud-images.ubuntu.com/releases"
MIN_VERSION="18.04"
LTS_ONLY="1"
ARCH="amd64"
EXCLUDE_END_OF_REGULAR_SUPPORT="0"
FALLBACK_SERIES="18.04:bionic 20.04:focal 22.04:jammy 24.04:noble"
IMAGE_PATTERNS="ubuntu-{version}-server-cloudimg-{arch}.img ubuntu-{version}-server-cloudimg-{arch}-disk-kvm.img"
CURL_RETRY="3"
CURL_CONNECT_TIMEOUT="20"
CURL_MAX_TIME="0"
VERIFY_SHA256="1"

# Ubuntu package mirror targets
LEGACY_MIRROR_BASE_URL="http://mirrors.openlandscape.cloud/ubuntu"
OLD_RELEASES_URL="https://old-releases.ubuntu.com/ubuntu"
OFFICIAL_ARCHIVE_URL="http://archive.ubuntu.com/ubuntu"
OFFICIAL_SECURITY_URL="http://security.ubuntu.com/ubuntu"
