{
  "os": "debian",
  "enabled": true,
  "min_version": "12",
  "max_version": null,
  "selection_policy": "latest",
  "release_channel": "stable",
  "default_arch": "x86_64",
  "notes": "Debian with dynamic upstream discovery. Supports explicit, auto, and latest modes.",
  "aliases": {
    "bookworm": "12",
    "trixie": "13"
  },
  "architectures": {
    "amd64": "x86_64",
    "x86_64": "x86_64",
    "arm64": "aarch64",
    "aarch64": "aarch64"
  },
  "discovery": {
    "method": "html_directory_listing",
    "url": "https://cloud.debian.org/images/cloud/",
    "version_pattern": "^(bookworm|trixie|sid)/?$",
    "release_mapping": {
      "bookworm": "12",
      "trixie": "13",
      "sid": "unstable"
    },
    "exclude_unstable": true
  },
  "sources": {
    "12": {
      "release_name": "bookworm",
      "artifact_type": "qcow2",
      "listing_url": "https://cloud.debian.org/images/cloud/bookworm/latest/",
      "filename_patterns": [
        "debian-12-generic-amd64.qcow2",
        "debian-12-generic-arm64.qcow2"
      ],
      "checksum_file": "SHA512SUMS",
      "checksum_algorithm": "sha512"
    },
    "13": {
      "release_name": "trixie",
      "artifact_type": "qcow2",
      "listing_url": "https://cloud.debian.org/images/cloud/trixie/latest/",
      "filename_patterns": [
        "debian-13-generic-amd64.qcow2",
        "debian-13-generic-arm64.qcow2"
      ],
      "checksum_file": "SHA512SUMS",
      "checksum_algorithm": "sha512"
    }
  }
}
