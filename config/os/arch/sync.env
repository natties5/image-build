# config/os/arch/sync.env — Discovery rules for Arch Linux cloud images.
# Upstream: https://geo.mirror.pkgbuild.com/images/latest/

OS_FAMILY=arch
MIN_VERSION=latest
TRACKED_VERSIONS=latest
AUTO_DISCOVER=0
LTS_ONLY=0
DISCOVERY_MODE=checksum_driven
LATEST_LOGIC=current_folder
INDEX_URL_TEMPLATE=https://geo.mirror.pkgbuild.com/images/latest
CHECKSUM_FILE=Arch-Linux-x86_64-cloudimg.qcow2.SHA256
HASH_ALGO=sha256
ARCH_PRIORITY=x86_64
FORMAT_PRIORITY=qcow2
IMAGE_REGEX=^Arch-Linux-x86_64-cloudimg\.qcow2$
DRY_RUN_SUPPORTED=yes
