# config/os/rocky/sync.env — Discovery rules for Rocky Linux cloud images.
# Upstream: https://dl.rockylinux.org/pub/rocky/

OS_FAMILY="rocky"
MIN_VERSION="8"

# Space-separated list of versions to track (all >= MIN_VERSION)
TRACKED_VERSIONS="8 9 10"
AUTO_DISCOVER="1"
LTS_ONLY="0"

# checksum_driven: fetch CHECKSUM file from the images directory
DISCOVERY_MODE="checksum_driven"

# current_folder: CHECKSUM file contains "latest" symlink entries
LATEST_LOGIC="current_folder"

INDEX_URL_TEMPLATE="https://dl.rockylinux.org/pub/rocky/{VERSION}/images/x86_64"

# The checksum file in the images directory
CHECKSUM_FILE="CHECKSUM"

HASH_ALGO="sha256"
ARCH_PRIORITY="x86_64 amd64"
FORMAT_PRIORITY="qcow2"

# Match Rocky Linux GenericCloud latest image
# Rocky 8/9 example: Rocky-9-GenericCloud.latest.x86_64.qcow2
# Rocky 10 example:  Rocky-10-GenericCloud-Base.latest.x86_64.qcow2
IMAGE_REGEX="^Rocky-{VERSION}-GenericCloud(-Base)?\.latest\.x86_64\.qcow2$"

DRY_RUN_SUPPORTED="yes"
