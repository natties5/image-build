# Fedora official cloud image auto-discover policy
OS_FAMILY="fedora"
OS_IMPLEMENTED="yes"
FEDORA_RELEASES_URL="https://download.fedoraproject.org/pub/fedora/linux/releases"
FEDORA_ARCHIVE_URL="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases"
MIN_VERSION="42"
MAX_VERSION="43"
ALLOW_EOL="0"
ARCH="x86_64"
CURL_RETRY="3"
CURL_CONNECT_TIMEOUT="20"
CURL_MAX_TIME="0"
VERIFY_SHA256="1"
