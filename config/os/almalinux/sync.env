# config/os/almalinux/sync.env — Discovery rules for AlmaLinux cloud images.
# Upstream: https://repo.almalinux.org/almalinux/

OS_FAMILY="almalinux"
MIN_VERSION="8"

# Space-separated list of versions to track (all >= MIN_VERSION)
TRACKED_VERSIONS="8 9"
AUTO_DISCOVER="1"
LTS_ONLY="0"

# checksum_driven: fetch the CHECKSUM file from the images directory
DISCOVERY_MODE="checksum_driven"

# current_folder: CHECKSUM file contains "latest" symlink entries
LATEST_LOGIC="current_folder"

INDEX_URL_TEMPLATE="https://repo.almalinux.org/almalinux/{VERSION}/cloud/x86_64/images"

# The checksum file in the images directory
CHECKSUM_FILE="CHECKSUM"

HASH_ALGO="sha256"
ARCH_PRIORITY="x86_64 amd64"
FORMAT_PRIORITY="qcow2"

# Match AlmaLinux GenericCloud latest image
# Example: AlmaLinux-9-GenericCloud-latest.x86_64.qcow2
IMAGE_REGEX="^AlmaLinux-{VERSION}-GenericCloud-latest\.x86_64\.qcow2$"

DRY_RUN_SUPPORTED="yes"
