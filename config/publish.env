# Final image publish config
PIPELINE_ROOT=""

# Naming
FINAL_IMAGE_NAME_TEMPLATE="ubuntu-{version}-golden"
FINAL_IMAGE_VISIBILITY="private"
FINAL_IMAGE_TAGS="stage:final,os:ubuntu"

# Behavior when final image name already exists: error | skip | replace
ON_FINAL_EXISTS="error"

# Wait policy for final image upload
WAIT_FOR_FINAL_ACTIVE="yes"
WAIT_FINAL_TIMEOUT_SECONDS="3600"
WAIT_FINAL_INTERVAL_SECONDS="10"

# Cleanup after publish
DELETE_SERVER_AFTER_PUBLISH="yes"
DELETE_VOLUME_AFTER_PUBLISH="yes"
DELETE_BASE_IMAGE_AFTER_PUBLISH="yes"

# Optional extra properties
SET_OS_DISTRO_PROPERTY="yes"
SET_OS_VERSION_PROPERTY="yes"
