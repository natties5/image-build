# Final image publish config
PIPELINE_ROOT=""

# Final image naming:
# result example: ubuntu-24.04-complete-20260318
FINAL_IMAGE_NAME_TEMPLATE="ubuntu-{version}-complete-{date}"

# Visibility after image becomes active: private | public | community | shared
FINAL_IMAGE_VISIBILITY="private"

# Tags applied after image becomes active
FINAL_IMAGE_TAGS="stage:complete,os:ubuntu"

# Behavior when final image name already exists: error | skip | replace
ON_FINAL_EXISTS="error"

# Wait policy for final image upload
WAIT_FOR_FINAL_ACTIVE="yes"
WAIT_FINAL_TIMEOUT_SECONDS="3600"
WAIT_FINAL_INTERVAL_SECONDS="10"

# Cleanup order:
# 1) delete server
# 2) wait volume available
# 3) create final image from volume
# 4) wait image active
# 5) delete volume
# 6) delete base image
DELETE_SERVER_BEFORE_PUBLISH="yes"
DELETE_VOLUME_AFTER_PUBLISH="yes"
DELETE_BASE_IMAGE_AFTER_PUBLISH="yes"

# Optional extra properties applied AFTER image is active
SET_OS_DISTRO_PROPERTY="yes"
SET_OS_VERSION_PROPERTY="yes"
