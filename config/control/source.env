# ปล่อยว่างเพื่อให้ script ใช้ root ของ repo อัตโนมัติ
PIPELINE_ROOT=""

# Official Ubuntu Cloud Images released builds
UBUNTU_RELEASES_BASE_URL="https://cloud-images.ubuntu.com/releases"

# policy ที่คุณขอ: เริ่มต่ำสุด 18.04 LTS แล้วทำจนถึงตัวล่าสุดที่ script หาเจอ
MIN_VERSION="18.04"
LTS_ONLY="1"
ARCH="amd64"
EXCLUDE_END_OF_REGULAR_SUPPORT="0"

# fallback ชุดที่ใช้เทสต์ตอนนี้
FALLBACK_SERIES="18.04:bionic 20.04:focal 22.04:jammy 24.04:noble"

# ลำดับชื่อไฟล์ที่ script จะลองหา
# ตัวแรกคือ pattern หลัก
# ตัวที่สองเป็น fallback กันกรณีบาง release page ใช้ -disk-kvm.img
IMAGE_PATTERNS="ubuntu-{version}-server-cloudimg-{arch}.img ubuntu-{version}-server-cloudimg-{arch}-disk-kvm.img"

# ถ้าปล่อยว่าง script จะสร้าง relative จาก repo root
CACHE_DIR=""
LOG_DIR=""
MANIFEST_DIR=""
TMP_DIR=""

# download tuning
CURL_RETRY="3"
CURL_CONNECT_TIMEOUT="20"
CURL_MAX_TIME="0"

# verify checksum
VERIFY_SHA256="1"