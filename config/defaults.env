# config/defaults.env — Project-wide tracked defaults (no secrets).
# Sourced by phases that need fallback values before OS-specific config.

# ─── Sync defaults ────────────────────────────────────────────────────────────
DEFAULT_ARCH_PRIORITY="amd64 x86_64"
DEFAULT_FORMAT_PRIORITY="img qcow2"
DEFAULT_HASH_ALGO="sha256"
DEFAULT_DISCOVERY_MODE="checksum_driven"
DEFAULT_DRY_RUN_SUPPORTED="yes"

# Curl timeout (seconds) for checksum file fetch
CURL_FETCH_TIMEOUT=30

# Download timeout (seconds) for full image download
DOWNLOAD_TIMEOUT=3600

# ─── Pipeline defaults ────────────────────────────────────────────────────────
# How long to wait for OpenStack resources (seconds)
WAIT_VOLUME_TIMEOUT=600
WAIT_SERVER_TIMEOUT=600
WAIT_IMAGE_TIMEOUT=1800
WAIT_POLL_INTERVAL=15

# Default volume size for boot volume (GB)
DEFAULT_VOLUME_SIZE_GB=20

# ─── Guest defaults ───────────────────────────────────────────────────────────
DEFAULT_SSH_PORT=22
DEFAULT_SSH_USER=root
DEFAULT_SSH_AUTH_MODE=password

# ─── Workspace defaults ───────────────────────────────────────────────────────
# Maximum age of a cached image before re-verification (days)
IMAGE_CACHE_MAX_AGE_DAYS=30
