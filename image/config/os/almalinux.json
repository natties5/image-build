{
  "os": "almalinux",
  "enabled": true,
  "min_version": "8",
  "max_version": null,
  "selection_policy": "explicit",
  "release_channel": "stable",
  "default_arch": "x86_64",
  "notes": "AlmaLinux with dynamic upstream version discovery supporting versions 8, 9, 10+. Stable releases only.",
  "aliases": {},
  "architectures": {
    "amd64": "x86_64",
    "x86_64": "x86_64",
    "arm64": "aarch64",
    "aarch64": "aarch64"
  },
  "discovery": {
    "method": "html_directory_listing",
    "url": "https://repo.almalinux.org/almalinux/",
    "version_pattern": "^([0-9]+)/?$",
    "exclude_patterns": ["^\\.?", "^lost\\+found$", "^beta$", "^testing$"],
    "notes": "Excludes beta and testing directories to ensure only stable releases are discovered"
  },
  "sources": {
    "8": {
      "release_name": "8",
      "artifact_type": "qcow2",
      "listing_url": "https://repo.almalinux.org/almalinux/8/cloud/x86_64/images/",
      "filename_patterns": [
        "AlmaLinux-8-GenericCloud-latest.x86_64.qcow2"
      ],
      "checksum_file": "CHECKSUM",
      "checksum_algorithm": "sha256"
    },
    "9": {
      "release_name": "9",
      "artifact_type": "qcow2",
      "listing_url": "https://repo.almalinux.org/almalinux/9/cloud/x86_64/images/",
      "filename_patterns": [
        "AlmaLinux-9-GenericCloud-latest.x86_64.qcow2"
      ],
      "checksum_file": "CHECKSUM",
      "checksum_algorithm": "sha256"
    },
    "10": {
      "release_name": "10",
      "artifact_type": "qcow2",
      "listing_url": "https://repo.almalinux.org/almalinux/10/cloud/x86_64/images/",
      "filename_patterns": [
        "AlmaLinux-10-GenericCloud-latest.x86_64.qcow2"
      ],
      "checksum_file": "CHECKSUM",
      "checksum_algorithm": "sha256"
    }
  }
}
