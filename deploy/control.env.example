# Jump-host control settings (safe tracked template).
# Copy to deploy/local/control.env and edit locally.

# Option A: use SSH alias from deploy/local/ssh_config.
JUMP_HOST_ALIAS="jump-image-build"

# Option B: direct user/host (used when alias is empty).
JUMP_HOST_USER=""
JUMP_HOST_ADDR=""
JUMP_HOST_PORT="22"

# Repository path and branch on jump host.
JUMP_HOST_REPO_PATH="/root/build_image"
JUMP_HOST_BRANCH="codex/hardening-ubuntu"
JUMP_HOST_REPO_URL=""

# Controller defaults
JUMP_MODE_DEFAULT="manual"

# Local SSH file locations
JUMP_SSH_CONFIG_FILE=""
JUMP_SSH_KEY_FILE=""
