# ─── Settings (private — never commit) ───────────────────────────────────────
settings/*.env
!settings/*.env.template
settings/openrc-file/*.sh
!settings/openrc-file/test-*.sh
settings/openrc-file/*.env
settings/openrc-file/*.rc
runtime/session/

# ─── Workspace (downloaded images — large binaries) ───────────────────────────
workspace/

# ─── Runtime artifacts ────────────────────────────────────────────────────────
runtime/
logs/
cache/
tmp/

# ─── Legacy artifacts ─────────────────────────────────────────────────────────
deploy/local/**
!deploy/local/.gitkeep
manifests/**/*.tsv
manifests/**/*.json

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
package.json
package-lock.json
