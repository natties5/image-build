# Settings (private - never commit)
settings/
!settings/*.env.example
!settings/README.md

# Local-only jump-host files (backward compat)
deploy/local/**
!deploy/local/.gitkeep

# Credentials
config/credentials/*.env
!config/credentials/*.env.example

# Runtime/build artifacts
cache/**
tmp/**
runtime/state/**
logs/*.log
logs/**/*.log
manifests/**/*.tsv
manifests/**/*.json

# Node
node_modules/
package.json
package-lock.json

# OS
.DS_Store
